{
  "name": "aegis-exam-integrity",
  "version": "4.0.0",
  "description": "Advanced Exam Guardrail Integrity System",
  "private": true,
  "scripts": {
    "setup": "npm run setup:backend && npm run setup:frontend",
    "setup:backend": "cd backend && pip install -r requirements.txt",
    "setup:frontend": "cd admin-portal && npm install",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd backend && python main.py",
    "dev:frontend": "cd admin-portal && npm run dev",
    "dev:ai": "cd ai-engine && python main_service.py"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
